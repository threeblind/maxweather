# Local development only. Do not put real secrets in this file.
#
# GitHub Actions should use repository Secrets / Variables instead of .env:
# Settings > Secrets and variables > Actions.

# Push notification API used by scripts/generate_report.py
PROD_PUSH_API_URL=https://ekiden-push-server.onrender.com
API_SECRET_KEY=

# Daily summary generation used by scripts/generate_daily_summary.py
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Optional: station image generation used by scripts/get_station_images.py
GOOGLE_MAPS_API_KEY=

# Optional: cache settings for push_server.py or future backend code
MOMENTO_API_KEY=
MOMENTO_CACHE_NAME=high-daigaku-ekiden

# Optional: push_server.py runtime settings. Configure these on Render, not GitHub Pages.
SUPABASE_URL=
SUPABASE_KEY=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_MAILTO=
FLASK_ENV=development
PROD_CORS_ORIGIN=
DEV_CORS_ORIGIN=
